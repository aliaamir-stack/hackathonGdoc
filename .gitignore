# ============================================================
# PULSE — .gitignore (All modules)
# ============================================================

# --- Environment variables — NEVER commit secrets ---
.env
.env.local
.env.*.local
.env.production
backend/.env

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
*.so
*.egg-info/
dist/
build/
*.egg

# --- Virtual environments ---
venv/
.venv/
env/
ENV/

# --- ChromaDB local data ---
chroma_db/
chroma.log

# --- Database ---
pulse.db
celerybeat-schedule

# --- Test outputs ---
test_triage_output.pdf
.pytest_cache/
htmlcov/
.coverage
*.log

# --- Test images ---
test_pills/*.jpg
test_pills/*.png
test_pills/*.jpeg

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE ---
.vscode/
.idea/
*.suo
*.user
*.swp
*.swo
*~

# --- Docker ---
docker-compose.override.yml
