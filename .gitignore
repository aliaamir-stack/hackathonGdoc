# ============================================================
# PULSE — .gitignore (All modules)
# ============================================================

# --- Environment variables — NEVER commit secrets ---
.env
.env.local
.env.*.local
.env.production
backend/.env

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
*.pyc
*.pyo
*.pyd

# --- Virtual environments ---
venv/
.venv/
env/
ENV/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
*.suo
*.user

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Test outputs ---
.pytest_cache/
htmlcov/
.coverage
*.log
test_triage_output.pdf

# --- Database / Background ---
pulse.db
celerybeat-schedule

# --- ChromaDB local data ---
chroma_db/
chroma.log

# --- Test images ---
test_pills/*.jpg
test_pills/*.png
test_pills/*.jpeg

# --- Docker ---
docker-compose.override.yml
