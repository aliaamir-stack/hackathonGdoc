# ============================================================
# PULSE — Member 5 Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# --- AI ENGINE (Google Gemini) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- WHATSAPP EMERGENCY ALERTS (CallMeBot) ---
# One-time setup:
# 1. Save +34 644 31 22 77 in your phone contacts as "CallMeBot"
# 2. Open WhatsApp, send this message to that number:
#    "I allow callmebot to send me messages"
# 3. Wait for confirmation — you'll get your API key
# 4. Fill in your phone (with country code) and API key below
WHATSAPP_PHONE=+92300XXXXXXX
WHATSAPP_API_KEY=your_callmebot_api_key_here

# --- OCR ENGINE ---
# Windows: usually C:\Program Files\Tesseract-OCR\tesseract.exe
# Mac/Linux: usually /usr/bin/tesseract or /usr/local/bin/tesseract
TESSERACT_PATH=

# --- API CONFIGURATION ---
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development

# --- EXTERNAL APIs (no keys needed) ---
# OpenFDA: https://api.fda.gov/drug/ndc.json
