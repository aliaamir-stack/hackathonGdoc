# ============================================================
# PULSE — Member 5 Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# --- AI ENGINE (Google Gemini) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- EMAIL EMERGENCY ALERTS (Gmail SMTP) ---
# Setup steps:
# 1. Go to myaccount.google.com → Security
# 2. Enable "2-Step Verification" if not already on
# 3. Go to myaccount.google.com → Security → App passwords
# 4. Create an app password (select "Mail" and "Windows Computer")
# 5. Copy the 16-character password below
ALERT_EMAIL=your_gmail@gmail.com
ALERT_EMAIL_PASSWORD=your_16_char_app_password
# Optional: who receives alerts (defaults to ALERT_EMAIL if empty)
ALERT_RECIPIENT_EMAIL=

# --- OCR ENGINE ---
TESSERACT_PATH=

# --- API CONFIGURATION ---
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
