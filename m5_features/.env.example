# ============================================================
# PULSE — Member 5 Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# --- AI ENGINE (Google Gemini) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- TELEGRAM EMERGENCY ALERTS ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- OCR ENGINE ---
# Windows: usually C:\Program Files\Tesseract-OCR\tesseract.exe
# Mac/Linux: usually /usr/bin/tesseract or /usr/local/bin/tesseract
TESSERACT_PATH=

# --- API CONFIGURATION ---
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development

# --- EXTERNAL APIs (no keys needed) ---
# OpenFDA: https://api.fda.gov/drug/ndc.json
# OSRM: http://router.project-osrm.org
